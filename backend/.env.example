# Скопируйте в .env и измените для продакшена
SECRET_KEY=change-me-to-long-random-string-min-32-chars
DATABASE_URL=sqlite:///./ftservice.db
# PostgreSQL (прод): postgresql+psycopg2://user:pass@host:5432/ftservice
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,exp://localhost:19000,null,*
ACCESS_TOKEN_EXPIRE_MINUTES=10080
WHATSAPP_PHONE=996700000000
TELEGRAM_USERNAME=ftservice_kg
CITY=Бишкек
RETURN_DAYS=3
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=8
MAX_UPLOAD_FILES=10
PUBLIC_BASE_URL=https://api.your-domain.kg
